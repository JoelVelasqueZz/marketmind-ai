# LLM provider: mock | gemini | claude | deepseek
LLM_MODE=mock

# Gemini (motor principal)
GOOGLE_API_KEY=
LLM_MODEL=gemini-flash-latest

# Claude (alterno, opcional)
ANTHROPIC_API_KEY=

# DeepSeek (alterno gratuito, opcional). Deja DEEPSEEK_BASE_URL como esta para
# usar la API oficial de DeepSeek, o pon https://openrouter.ai/api/v1 + una key
# de OpenRouter para usar su capa gratuita en su lugar.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Backend
# SQLite por defecto (sin instalacion extra). Para Postgres persistente (ej. Neon,
# recomendado en produccion para que los datos no se borren en cada redeploy):
# DATABASE_URL=postgresql://usuario:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=sqlite:///./data/app.db
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
